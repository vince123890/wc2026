# ============================================================
# WC 2026 PREDICTOR — ENV SETUP GUIDE
# Salin file ini ke .env.local dan isi sesuai instruksi
# ============================================================

# ── DATA PROVIDERS (server-side) ────────────────────────────

# worldcup26.ir — GRATIS. Live scores, standings, events, 48 tim, 104 match.
# Cara: Daftar di https://worldcup26.ir → Login → salin JWT token. Berlaku 84 hari.
WC26_JWT=

# API-Football — GRATIS (100 req/hari). Lineup, events, standings.
# Cara: https://api-football.com → Sign Up Free → Dashboard → API Key
APIF_KEY=

# BALLDONTLIE — Teams/Stadiums GRATIS | Sisanya GOAT $39.99/bln.
# Opsional — hanya isi jika kamu berlangganan GOAT tier.
BALLDONTLIE_KEY=

# ── AI PROVIDERS (server-side, opsional — bisa BYOK via Settings) ───────────

# Anthropic Claude — Pay-as-you-go, Haiku sangat hemat.
# Atau biarkan kosong dan isi via Settings (BYOK, disimpan di browser).
# Cara: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=

# Google Gemini — Flash punya free quota harian.
# Cara: https://aistudio.google.com → Get API key
GEMINI_API_KEY=

# ── SUPABASE — GRATIS (free tier cukup) ─────────────────────
# Leaderboard global. Tanpa ini, leaderboard lokal saja.
# Cara: https://supabase.com → New project → Settings → API
# Lalu jalankan SQL dari README.md di SQL Editor Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# MINIMUM SETUP (agar semua fitur utama aktif):
# 1. WC26_JWT     — live scores (gratis, ~5 menit)
# 2. APIF_KEY     — lineup & events (gratis, ~5 menit)
# 3. Supabase URL+KEY — leaderboard global (gratis, ~10 menit)
# 4. API key AI   — bisa via Settings, tidak perlu di sini
# ============================================================
